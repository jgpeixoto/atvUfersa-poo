<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.universidade.controller.WelcomeController"
      styleClass="welcome-root"
      stylesheets="@../css/styles.css"
      alignment="CENTER"
      spacing="30">

    <padding>
        <Insets top="60" right="40" bottom="60" left="40"/>
    </padding>

    <!-- Logo da faculdade -->
    <ImageView fitWidth="260" fitHeight="260" preserveRatio="true">
        <image>
            <Image url="@../images/logo.png"/>
        </image>
    </ImageView>

    <!-- Texto de boas-vindas -->
    <TextFlow textAlignment="CENTER" styleClass="welcome-text-flow">
        <Text text="Bem-vindo à " styleClass="welcome-text-regular"/>
        <Text text="Faculdade Weitinho" styleClass="welcome-text-bold"/>
    </TextFlow>

    <!-- Botão de login -->
    <Button text="⇥  LOGIN" fx:id="btnLogin" onAction="#abrirLogin" styleClass="btn-login"/>

</VBox>
