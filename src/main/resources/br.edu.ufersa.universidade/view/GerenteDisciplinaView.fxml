<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.universidade.controller.GerenteDisciplinaController"
            maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650.0" minWidth="1280.0" prefHeight="650.0" prefWidth="1280.0"
            styleClass="app-root"
            stylesheets="@../css/styles.css">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="220" styleClass="sidebar" alignment="TOP_CENTER" spacing="0">

            <VBox alignment="CENTER" styleClass="sidebar-logo-box">
                <padding>
                    <Insets top="30" bottom="30" left="0" right="0"/>
                </padding>
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png"/>
                    </image>
                </ImageView>
            </VBox>

            <VBox styleClass="sidebar-menu" spacing="0">
                <VBox styleClass="sidebar-item, sidebar-item-active" alignment="CENTER" spacing="8">
                    <padding>
                        <Insets top="18" bottom="18" left="0" right="0"/>
                    </padding>
                    <Label text="Disciplina" styleClass="sidebar-item-label"/>
                    <Label text="🗓" styleClass="sidebar-item-icon"/>
                </VBox>

                <VBox styleClass="sidebar-item" alignment="CENTER" spacing="8">
                    <padding>
                        <Insets top="18" bottom="18" left="0" right="0"/>
                    </padding>
                    <Label text="Turmas" styleClass="sidebar-item-label"/>
                    <Label text="👥" styleClass="sidebar-item-icon"/>
                </VBox>

                <VBox styleClass="sidebar-item" alignment="CENTER" spacing="8">
                    <padding>
                        <Insets top="18" bottom="18" left="0" right="0"/>
                    </padding>
                    <Label text="Professores" styleClass="sidebar-item-label"/>
                    <Label text="🎒" styleClass="sidebar-item-icon"/>
                </VBox>

                <VBox styleClass="sidebar-item" alignment="CENTER" spacing="8">
                    <padding>
                        <Insets top="18" bottom="18" left="0" right="0"/>
                    </padding>
                    <Label text="Alunos" styleClass="sidebar-item-label"/>
                    <Label text="👤" styleClass="sidebar-item-icon"/>
                </VBox>
            </VBox>

        </VBox>
    </left>

    <!-- ===================== CONTEÚDO ===================== -->
    <center>
        <VBox styleClass="app-content">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" styleClass="app-header">
                <padding>
                    <Insets top="20" right="40" bottom="20" left="40"/>
                </padding>
                <Label text="Gerente" styleClass="app-header-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Sair  ➜" fx:id="btnSair" onAction="#sair" styleClass="btn-sair"/>
            </HBox>

            <!-- Corpo -->
            <VBox styleClass="app-body" spacing="20" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Busca + botão adicionar -->
                <HBox spacing="15" alignment="CENTER">
                    <TextField fx:id="campoBusca" promptText="Buscar por nome, código..."
                               styleClass="search-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Adicionar discip.  ➕" fx:id="btnAdicionar" onAction="#adicionarDisciplina"
                            styleClass="btn-adicionar"/>
                </HBox>

                <!-- Tabela -->
                <TableView fx:id="tabelaDisciplinas" styleClass="app-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="300"/>
                        <TableColumn fx:id="colCodigo" text="Código" prefWidth="300"/>
                        <TableColumn fx:id="colAjustes" text="Ajustes" prefWidth="140"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>
