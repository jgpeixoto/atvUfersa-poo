<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>

<BorderPane styleClass="root-bg" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.universidade.controller.ProfessorFrequenciaController"
            maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650.0" minWidth="1280.0" prefHeight="650.0" prefWidth="1280.0">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox styleClass="sidebar" alignment="TOP_CENTER" spacing="0">
            <StackPane prefHeight="120">
                <ImageView fitWidth="84" fitHeight="84" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
            </StackPane>

            <VBox styleClass="sidebar-item" alignment="CENTER" spacing="4" onMouseClicked="#handleAbrirTurmas">
                <Label text="Turmas" styleClass="sidebar-item" />
                <Label text="🎓" style="-fx-font-size: 20px; -fx-text-fill: #d6def2;" />
            </VBox>

            <VBox styleClass="sidebar-item-active" alignment="CENTER" spacing="4">
                <Label text="Frequência" styleClass="sidebar-item-active" />
                <Label text="📋" style="-fx-font-size: 20px; -fx-text-fill: white;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <!-- ===================== CONTEÚDO ===================== -->
    <center>
        <VBox spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>

            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <Label text="Professor" styleClass="topbar-subtitle" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Frequência" styleClass="topbar-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Sair  ➜" styleClass="btn-sair" onAction="#handleSair" />
            </HBox>

            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">

                <HBox styleClass="search-bar" alignment="CENTER_LEFT" spacing="8" maxWidth="460">
                    <ComboBox fx:id="comboAluno" promptText="Buscar aluno...." HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                </HBox>

                <TableView fx:id="tableFrequencia" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" text="Nome" prefWidth="180" />
                        <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="110" />
                        <TableColumn fx:id="colData" text="Data" prefWidth="120" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>