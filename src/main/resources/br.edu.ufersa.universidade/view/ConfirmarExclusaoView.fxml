<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox maxWidth="500" prefWidth="500" spacing="20" styleClass="confirm-popup" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ufersa.universidade.controller.ConfirmarExclusaoController">

    <padding>
        <Insets bottom="25" left="30" right="30" top="25" />
    </padding>

    <!-- Cabeçalho: título + botão fechar (X) -->
    <HBox alignment="CENTER_LEFT">
        <Label styleClass="confirm-title" text="Confirmar exclusão" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#fechar" styleClass="btn-fechar-popup" text="✕" />
    </HBox>

    <!-- Ícone de alerta + mensagem (texto fixo) -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label styleClass="confirm-icon" text="⚠" />
        <Label styleClass="confirm-message" text="Tem certeza que deseja excluir este item?" wrapText="true" />
    </HBox>

    <!-- Botões -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button onAction="#cancelar" styleClass="btn-cancelar-popup" text="Cancelar" />
        <Button onAction="#confirmarExclusao" styleClass="btn-excluir-popup" text="Excluir  🗑" />
    </HBox>

</VBox>
